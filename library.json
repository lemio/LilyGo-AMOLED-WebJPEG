{
  "name": "LilyGo-AMOLED-WebJPEG",
  "version": "1.2.0",
  "description": "Streams a browser tab, window, or camera to a LilyGo T-Display AMOLED board over WiFi as MJPEG or H.264. Fork of LilyGo-AMOLED-Series trimmed to these two examples.",
  "keywords": "lilygo,amoled,webjpeg,webh264,streaming,mjpeg,h264,websocket",
  "authors": [
    {
      "name": "Xinyuan-LilyGO",
      "url": "https://github.com/Xinyuan-LilyGO"
    },
    {
      "name": "LewisHe",
      "url": "https://github.com/lewisxhe",
      "maintainer": true
    },
    {
      "name": "lemio",
      "url": "https://github.com/lemio",
      "maintainer": true
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/lemio/LilyGo-AMOLED-WebJPEG.git"
  },
  "homepage": "https://github.com/lemio/LilyGo-AMOLED-WebJPEG",
  "export": {
    "include": [
      "LICENSE",
      "library.json",
      "library.properties",
      "README.MD",
      "src/*",
      "examples/*"
    ]
  },
  "dependencies": [
    {
      "owner": "lvgl",
      "name": "lvgl",
      "version": "8.4.0"
    },
    {
      "owner": "lewisxhe",
      "name": "XPowersLib",
      "version": "0.2.7"
    },
    {
      "owner": "lewisxhe",
      "name": "SensorLib",
      "version": "0.2.4"
    },
    {
      "owner": "bodmer",
      "name": "TFT_eSPI",
      "version": "2.5.31"
    },
    {
      "owner": "bodmer",
      "name": "JPEGDecoder",
      "version": "^2.0.0"
    },
    {
      "owner": "esp32async",
      "name": "ESPAsyncWebServer",
      "version": "^3.9.2"
    },
    {
      "owner": "esp32async",
      "name": "AsyncTCP",
      "version": "^3.4.9"
    }
  ],
  "examples": ["examples/*/*.cpp"],
  "frameworks": ["arduino"],
  "platforms": "esp32",
  "headers": "LilyGo_AMOLED.h"
}
